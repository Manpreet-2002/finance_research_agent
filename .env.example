# Runtime environment
APP_ENV=dev

# LLM configuration (V1)
LLM_PROVIDER=google
LLM_MODEL=gemini-3
GOOGLE_API_KEY=

# Google auth for Sheets/Drive workflows (OAuth required for V1)
GOOGLE_AUTH_MODE=oauth
GOOGLE_OAUTH_CLIENT_SECRET_FILE=credentials.json
GOOGLE_OAUTH_TOKEN_FILE=token.json

# Data provider routing (phase_v1 mixed approach)
FUNDAMENTALS_PROVIDER=finnhub
MARKET_DATA_PROVIDER=finnhub
NEWS_PROVIDER=tavily
WEB_SEARCH_PROVIDER=tavily
RATES_PROVIDER=fred
TRANSCRIPT_PROVIDER=alpha_vantage
CORPORATE_ACTIONS_PROVIDER=alpha_vantage
PEER_PROVIDER=finnhub
CONTRADICTION_CHECKER_PROVIDER=rule_based

# API credentials
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
TAVILY_API_KEY=
FRED_API_KEY=

# SEC access metadata (SEC asks for identifying User-Agent)
SEC_API_USER_AGENT=finance-research-agent/0.1 (name@domain.com)
SEC_CONTACT_EMAIL=

# Rates defaults and FRED series selection
FRED_RF_SERIES_ID=DGS10
DEFAULT_EQUITY_RISK_PREMIUM=0.05
DEFAULT_COST_OF_DEBT=0.055
DEFAULT_DEBT_WEIGHT=0.10
DEFAULT_TERMINAL_GROWTH=0.025

# DCF model defaults (used when not fetched directly)
DEFAULT_GROWTH_YEAR_1=0.05
DEFAULT_GROWTH_YEAR_2=0.04
DEFAULT_GROWTH_YEAR_3=0.03
DEFAULT_GROWTH_YEAR_4=0.03
DEFAULT_GROWTH_YEAR_5=0.03
DEFAULT_MARGIN_YEAR_5=0.30
DEFAULT_MARGIN_YEAR_10=0.30
DEFAULT_TAX_NORM=0.18
DEFAULT_DA_PCT=0.03
DEFAULT_CAPEX_PCT=0.02
DEFAULT_NWC_PCT=0.00
DEFAULT_RD_PCT=0.07
DEFAULT_RENT_PCT=0.01
DEFAULT_OTHER_ADJUSTMENT=0.0
DEFAULT_CAP_RD_TOGGLE=YES
DEFAULT_CAP_LEASE_TOGGLE=YES

# News fetch window
NEWS_LOOKBACK_DAYS=14

# Google Sheets files (template + centralized logbook)
SHEETS_TEMPLATE_FILE=Valuation_Template_TTM_TSM_RD_Lease_BankStyle_ExcelGraph_Logbook.xlsx
SHEETS_LOGBOOK_FILE=Valuation_Agent_Logbook_ExcelGraph.xlsx
